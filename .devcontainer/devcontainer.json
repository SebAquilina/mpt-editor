{
  "name": "mpt-editor",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [5173, 8000],
  "portsAttributes": {
    "5173": { "label": "mpt-editor frontend", "onAutoForward": "openPreview", "visibility": "public" },
    "8000": { "label": "mpt-editor backend", "onAutoForward": "silent", "visibility": "public" }
  }
}
